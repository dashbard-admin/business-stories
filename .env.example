# Copy this file to ".env" at the project root and fill in your
# secrets. The file ".env" is gitignored — only this template is
# committed.
#
# Loaded by pipeline/__init__.py at package import: any KEY=value
# line below is set into os.environ ONLY if not already defined,
# so explicit shell-export / cron / launchd values win.
#
# Keys can be quoted ('single' or "double") or bare. `export KEY=...`
# is also accepted (useful if you paste from a .envrc).

# ============================================================
# xAI Grok image-correction (S09 sub-phase)
# Get a key at: https://console.x.ai/
# ============================================================
XAI_API_KEY=

# Optional alias — code checks XAI_API_KEY first, then GROK_API_KEY.
# GROK_API_KEY=

# ============================================================
# ElevenLabs (premium TTS, optional). Wired but disabled by
# default — see config.yaml `tts.backend`. Added Batch D 2026-05-27.
# Get a key at: https://elevenlabs.io/api
# ============================================================
ELEVENLABS_API_KEY=

# ============================================================
# YouTube Analytics writeback (Batch E 2026-05-27, optional).
# Required only when cfg.youtube_analytics.enabled=true.
# Create OAuth 2.0 Client ID in Google Cloud Console (Desktop
# app), enable YouTube Data API v3 + YouTube Analytics API.
# Then run `python -m pipeline.hermes_orchestrator --authorize-youtube`
# once to do the browser dance. Refresh token cached at
# state/youtube_oauth_token.json (gitignored).
# ============================================================
YOUTUBE_OAUTH_CLIENT_ID=
YOUTUBE_OAUTH_CLIENT_SECRET=
